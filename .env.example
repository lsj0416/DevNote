# ----------------------------------------
# DevNote AI 환경변수 설정
# 이 파일을 복사해서 .env로 만들고 값을 채워주세요
# cp .env.example .env
# ----------------------------------------
# .env는 절대 Git에 올리지 마세요 (.gitignore에 추가 필수)
# ----------------------------------------

# ─── GitHub OAuth2 ───────────────────────
# GitHub > Settings > Developer settings > OAuth Apps에서 발급
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── JWT ─────────────────────────────────
# 32자 이상의 랜덤 문자열 (openssl rand -base64 32 로 생성 가능)
JWT_SECRET=

# ─── Database ────────────────────────────
DB_HOST=localhost
DB_NAME=devnote
DB_USERNAME=devnote
DB_PASSWORD=devnote1234

# ─── Redis ───────────────────────────────
REDIS_HOST=localhost
REDIS_PASSWORD=

# ─── OpenAI ──────────────────────────────
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# ─── AWS S3 ──────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=devnote-local

# ─── OAuth2 Redirect ─────────────────────
# 로컬: http://localhost:3000/oauth2/callback
# 운영: https://devnote.io/oauth2/callback
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/callback
